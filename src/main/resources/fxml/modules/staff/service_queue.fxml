<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.hotel.app.controller.ServiceQueueController"
      styleClass="content-area"
      spacing="20"
      stylesheets="@../../../css/main.css">

    <padding>
        <Insets top="30" right="30" bottom="30" left="30"/>
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="15">
        <VBox spacing="5">
            <Label text="Service Queue" styleClass="title-text"/>
            <Label text="Manage and track active guest requests in real-time." styleClass="subtitle-text"/>
        </VBox>
        <Region HBox.hgrow="ALWAYS"/>
        <VBox alignment="CENTER_RIGHT" spacing="5">
            <Label fx:id="pendingCountLabel" styleClass="stat-label"/>
            <Button text="&#x21BB; Refresh" styleClass="logout-btn" onAction="#handleRefresh"/>
        </VBox>
    </HBox>

    <HBox spacing="10">
        <Button fx:id="btnAll"         text="All Active"  styleClass="primary-btn" onAction="#handleFilterAll"/>
        <Button fx:id="btnPending"     text="Pending"     styleClass="logout-btn"  onAction="#handleFilterPending"/>
        <Button fx:id="btnInProgress"  text="In Progress" styleClass="logout-btn"  onAction="#handleFilterInProgress"/>
    </HBox>

    <VBox styleClass="card" VBox.vgrow="ALWAYS" spacing="15">
        <Label text="ACTIVE SERVICE REQUESTS" styleClass="section-title-red"/>

        <TableView fx:id="queueTable"
                   VBox.vgrow="ALWAYS"
                   styleClass="table-view">
            <columns>
                <TableColumn fx:id="colQRoom"    text="Room"      prefWidth="60"/>
                <TableColumn fx:id="colQGuest"   text="Guest"     prefWidth="130"/>
                <TableColumn fx:id="colQService" text="Service"   prefWidth="150"/>
                <TableColumn fx:id="colQQty"     text="Qty"       prefWidth="50"/>
                <TableColumn fx:id="colQNotes"   text="Notes"     prefWidth="160"/>
                <TableColumn fx:id="colQStatus"  text="Status"    prefWidth="110"/>
                <TableColumn fx:id="colQTime"    text="Requested" prefWidth="130"/>
                <TableColumn fx:id="colQCharge"  text="Charge"    prefWidth="90"/>
                <TableColumn fx:id="colQActions" text="Actions"   prefWidth="220"/>
            </columns>
            <placeholder>
                <Label text="No pending service requests" styleClass="muted-text"/>
            </placeholder>
        </TableView>
    </VBox>

    <HBox alignment="CENTER_LEFT" minHeight="30" styleClass="card" fx:id="feedbackContainer" visible="false" managed="false">
        <Label fx:id="feedbackLabel"
               styleClass="status-label"
               wrapText="true"/>
    </HBox>

</VBox>