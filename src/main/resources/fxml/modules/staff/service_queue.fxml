<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.hotel.app.controller.ServiceQueueController"
      styleClass="content-area"
      spacing="14"
      stylesheets="@../../../css/main.css">

    <VBox.margin>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </VBox.margin>

    <!-- ═══ Header ════════════════════════════════════════════ -->
    <HBox alignment="CENTER_LEFT" spacing="12">
        <Label text="Service Queue" styleClass="topbar-title"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="pendingCountLabel" styleClass="stat-label"/>
        <Button text="&#x21BB; Refresh" styleClass="logout-btn" onAction="#handleRefresh"/>
    </HBox>

    <!-- ═══ Filter buttons ════════════════════════════════════ -->
    <HBox spacing="8">
        <Button fx:id="btnAll"         text="All Active"  styleClass="primary-btn" onAction="#handleFilterAll"/>
        <Button fx:id="btnPending"     text="Pending"     styleClass="logout-btn"  onAction="#handleFilterPending"/>
        <Button fx:id="btnInProgress"  text="In Progress" styleClass="logout-btn"  onAction="#handleFilterInProgress"/>
    </HBox>

    <!-- ═══ Queue table ════════════════════════════════════════ -->
    <VBox styleClass="info-box" VBox.vgrow="ALWAYS" spacing="10">
        <Label text="ACTIVE SERVICE REQUESTS" styleClass="info-box-title"/>

        <TableView fx:id="queueTable"
                   VBox.vgrow="ALWAYS"
                   styleClass="dark-table">
            <columns>
                <!-- Data columns -->
                <TableColumn fx:id="colQRoom"    text="Room"      prefWidth="58"/>
                <TableColumn fx:id="colQGuest"   text="Guest"     prefWidth="128"/>
                <TableColumn fx:id="colQService" text="Service"   prefWidth="145"/>
                <TableColumn fx:id="colQQty"     text="Qty"       prefWidth="42"/>
                <TableColumn fx:id="colQNotes"   text="Notes"     prefWidth="158"/>
                <TableColumn fx:id="colQStatus"  text="Status"    prefWidth="100"/>
                <TableColumn fx:id="colQTime"    text="Requested" prefWidth="120"/>
                <TableColumn fx:id="colQCharge"  text="Charge"    prefWidth="78"/>
                <!-- Action buttons column (built programmatically in controller) -->
                <TableColumn fx:id="colQActions" text="Actions"   prefWidth="215"/>
            </columns>
            <placeholder>
                <Label text="No pending service requests" styleClass="muted-text"/>
            </placeholder>
        </TableView>
    </VBox>

    <!-- ═══ Feedback bar ═══════════════════════════════════════ -->
    <HBox alignment="CENTER_LEFT" minHeight="28">
        <Label fx:id="feedbackLabel"
               styleClass="muted-text"
               wrapText="true"
               visible="false"
               managed="false"/>
    </HBox>

</VBox>
