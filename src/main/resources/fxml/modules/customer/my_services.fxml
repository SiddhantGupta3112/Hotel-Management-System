<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.hotel.app.controller.ServiceController"
      styleClass="content-area"
      spacing="20"
      stylesheets="@../../../css/main.css">

    <padding>
        <Insets top="25" right="25" bottom="25" left="25"/>
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="15">
        <VBox spacing="5">
            <Label text="Hotel Services" styleClass="title-text"/>
            <Label text="Request room service or amenities directly to your door." styleClass="subtitle-text"/>
        </VBox>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="&#x21BB; Refresh" styleClass="logout-btn" onAction="#handleRefresh"/>
    </HBox>

    <VBox fx:id="bookingStatusBox" styleClass="card" spacing="15">
        <Label text="YOUR ACTIVE STAY" styleClass="section-title-purple"/>
        <HBox spacing="40" alignment="CENTER_LEFT">
            <VBox spacing="5">
                <Label text="ROOM" styleClass="stat-label"/>
                <Label fx:id="bookingRoomLabel" styleClass="stat-value-orange" text="—"/>
            </VBox>
            <VBox spacing="5">
                <Label text="CHECK-IN" styleClass="stat-label"/>
                <Label fx:id="bookingCheckInLabel" styleClass="stat-value" text="—"/>
            </VBox>
            <VBox spacing="5">
                <Label text="CHECK-OUT" styleClass="stat-label"/>
                <Label fx:id="bookingCheckOutLabel" styleClass="stat-value" text="—"/>
            </VBox>
            <VBox spacing="5">
                <Label text="STATUS" styleClass="stat-label"/>
                <Label fx:id="bookingStatusLabel" styleClass="stat-value-green" text="—"/>
            </VBox>
        </HBox>
    </VBox>

    <VBox fx:id="noBookingBox" styleClass="card" alignment="CENTER" spacing="15" minHeight="150" visible="false" managed="false">
        <Label text="No Active Booking Found" styleClass="title-text"/>
        <Label text="Services are only available during an active stay." styleClass="muted-text" alignment="CENTER" textAlignment="CENTER" wrapText="true" maxWidth="400"/>
    </VBox>

    <VBox fx:id="serviceSection" VBox.vgrow="ALWAYS" visible="false" managed="false">
        <SplitPane orientation="VERTICAL"
                   VBox.vgrow="ALWAYS"
                   dividerPositions="0.55"
                   style="-fx-background-color: transparent; -fx-padding: 0;">
            <items>

                <VBox styleClass="card" spacing="12">
                    <Label text="AVAILABLE SERVICES" styleClass="section-title-red"/>

                    <HBox spacing="15" alignment="CENTER_LEFT">
                        <VBox spacing="4">
                            <Label text="QTY" styleClass="field-label"/>
                            <TextField fx:id="quantityField" text="1" prefWidth="60" styleClass="form-control"/>
                        </VBox>
                        <VBox spacing="4" HBox.hgrow="ALWAYS">
                            <Label text="NOTES FOR STAFF" styleClass="field-label"/>
                            <TextField fx:id="notesField" promptText="Special instructions..." styleClass="form-control"/>
                        </VBox>
                    </HBox>

                    <TableView fx:id="serviceTable"
                               VBox.vgrow="ALWAYS"
                               minHeight="120"
                               styleClass="table-view">
                        <columns>
                            <TableColumn fx:id="colServiceName"     text="Service"     prefWidth="180"/>
                            <TableColumn fx:id="colServiceCategory" text="Category"    prefWidth="120"/>
                            <TableColumn fx:id="colServiceDesc"     text="Description" prefWidth="300"/>
                            <TableColumn fx:id="colServicePrice"    text="Price"       prefWidth="85"/>
                            <TableColumn fx:id="colServiceAction"   text="Action"      prefWidth="115"/>
                        </columns>
                        <placeholder>
                            <Label text="Loading catalog..." styleClass="muted-text"/>
                        </placeholder>
                    </TableView>
                </VBox>

                <VBox styleClass="card" spacing="12">
                    <Label text="MY REQUESTS FOR THIS STAY" styleClass="section-title-red"/>

                    <TableView fx:id="myRequestsTable"
                               VBox.vgrow="ALWAYS"
                               minHeight="100"
                               styleClass="table-view">
                        <columns>
                            <TableColumn fx:id="colReqService" text="Service"   prefWidth="180"/>
                            <TableColumn fx:id="colReqQty"     text="Qty"       prefWidth="55"/>
                            <TableColumn fx:id="colReqNotes"   text="Notes"     prefWidth="220"/>
                            <TableColumn fx:id="colReqStatus"  text="Status"    prefWidth="110"/>
                            <TableColumn fx:id="colReqTime"    text="Requested" prefWidth="150"/>
                            <TableColumn fx:id="colReqCancel"  text="Action"    prefWidth="105"/>
                        </columns>
                        <placeholder>
                            <Label text="No requests yet" styleClass="muted-text"/>
                        </placeholder>
                    </TableView>
                </VBox>

            </items>
        </SplitPane>
    </VBox>

    <HBox alignment="CENTER_LEFT" minHeight="25">
        <Label fx:id="requestErrorLabel" styleClass="error-text" visible="false" managed="false"/>
        <Label fx:id="requestSuccessLabel" styleClass="success-message" visible="false" managed="false"/>
    </HBox>

</VBox>