<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="20.0" styleClass="content-area" stylesheets="@../../../css/main.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1">
    <padding><Insets bottom="25" left="25" right="25" top="25" /></padding>

    <HBox spacing="20">
        <VBox HBox.hgrow="ALWAYS" styleClass="stat-card">
            <Label styleClass="stat-label" text="TOTAL REVENUE (TODAY)" />
            <Label styleClass="stat-value-green" text="₹45,200" />
        </VBox>
        <VBox HBox.hgrow="ALWAYS" styleClass="stat-card">
            <Label styleClass="stat-label" text="OCCUPANCY RATE" />
            <Label styleClass="stat-value" text="82%" />
        </VBox>
        <VBox HBox.hgrow="ALWAYS" styleClass="stat-card">
            <Label styleClass="stat-label" text="PENDING CHECK-INS" />
            <Label styleClass="stat-value" text="12" />
        </VBox>
    </HBox>

    <VBox spacing="10" VBox.vgrow="ALWAYS">
        <Label styleClass="topbar-title" text="Recent Bookings" />
        <TableView styleClass="dark-table" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn prefWidth="150" text="Customer" />
                <TableColumn prefWidth="100" text="Room" />
                <TableColumn prefWidth="120" text="Status" />
                <TableColumn prefWidth="120" text="Amount" />
            </columns>
        </TableView>
    </VBox>
</VBox>