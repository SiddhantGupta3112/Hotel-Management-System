<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<ScrollPane fitToWidth="true" styleClass="root-pane"
            stylesheets="@../../../css/main.css"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.hotel.app.controller.modules.manager.OverviewController">

    <VBox spacing="20" styleClass="root-pane">
        <padding>
            <Insets top="24" right="24" bottom="24" left="24"/>
        </padding>

        <HBox alignment="CENTER_LEFT" spacing="16">
            <VBox>
                <Label text="Dashboard Overview" styleClass="topbar-title"/>
                <Label text="Real-time hotel statistics and revenue" styleClass="muted-text"/>
            </VBox>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="Refresh Data" styleClass="logout-btn"
                    onAction="#handleRefresh" prefWidth="120"/>
        </HBox>

        <HBox spacing="16">
            <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
                <Label text="TOTAL ROOMS" styleClass="stat-label"/>
                <Label fx:id="totalRoomsLabel" styleClass="stat-value" text="—"/>
            </VBox>
            <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
                <Label text="AVAILABLE" styleClass="stat-label"/>
                <Label fx:id="availableRoomsLabel" styleClass="stat-value-green" text="—"/>
            </VBox>
            <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
                <Label text="OCCUPIED" styleClass="stat-label"/>
                <Label fx:id="occupiedRoomsLabel" styleClass="stat-value-red" text="—"/>
            </VBox>
            <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
                <Label text="MAINTENANCE" styleClass="stat-label"/>
                <Label fx:id="maintenanceRoomsLabel" styleClass="stat-value-orange" text="—"/>
            </VBox>
        </HBox>

        <HBox spacing="16">
            <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
                <Label text="TODAY'S REVENUE" styleClass="stat-label"/>
                <Label fx:id="todayRevenueLabel" styleClass="stat-value-green" text="₹ —"/>
            </VBox>
            <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
                <Label text="MONTH REVENUE" styleClass="stat-label"/>
                <Label fx:id="monthRevenueLabel" styleClass="stat-value-green" text="₹ —"/>
            </VBox>
            <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
                <Label text="YEAR REVENUE" styleClass="stat-label"/>
                <Label fx:id="yearRevenueLabel" styleClass="stat-value-green" text="₹ —"/>
            </VBox>
        </HBox>

        <HBox spacing="16">
            <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
                <Label text="TODAY CHECK-INS" styleClass="stat-label"/>
                <Label fx:id="todayCheckInsLabel" styleClass="stat-value-blue" text="—"/>
            </VBox>
            <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
                <Label text="TODAY CHECK-OUTS" styleClass="stat-label"/>
                <Label fx:id="todayCheckOutsLabel" styleClass="stat-value-blue" text="—"/>
            </VBox>
            <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
                <Label text="PENDING INVOICES" styleClass="stat-label"/>
                <Label fx:id="pendingInvoicesLabel" styleClass="stat-value-orange" text="—"/>
            </VBox>
        </HBox>

        <VBox styleClass="info-box" spacing="12">
            <Label text="ALERTS" styleClass="info-box-title"/>
            <HBox spacing="16">
                <VBox styleClass="stat-card" HBox.hgrow="ALWAYS" alignment="CENTER_LEFT">
                    <Label fx:id="overdueCheckoutsLabel" styleClass="stat-value-orange" text="—"/>
                    <Label text="Overdue check-outs" styleClass="stat-label"/>
                </VBox>
                <VBox styleClass="stat-card" HBox.hgrow="ALWAYS" alignment="CENTER_LEFT">
                    <Label fx:id="missedCheckinsLabel" styleClass="stat-value-red" text="—"/>
                    <Label text="Missed check-ins" styleClass="stat-label"/>
                </VBox>
                <VBox styleClass="stat-card" HBox.hgrow="ALWAYS" alignment="CENTER_LEFT">
                    <Label fx:id="pendingServicesLabel" styleClass="stat-value-blue" text="—"/>
                    <Label text="Pending service requests" styleClass="stat-label"/>
                </VBox>
            </HBox>
        </VBox>

    </VBox>
</ScrollPane>