<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="20.0" styleClass="content-area" stylesheets="@../../../css/main.css"
      xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.hotel.app.controller.OverviewController">

    <padding>
        <Insets bottom="25" left="25" right="25" top="25" />
    </padding>

    <HBox spacing="20">
        <VBox HBox.hgrow="ALWAYS" styleClass="stat-card">
            <Label styleClass="stat-label" text="TOTAL REVENUE (TODAY)" />
            <Label fx:id="revenueLabel" styleClass="stat-value-green" text="₹0" />
        </VBox>

        <VBox HBox.hgrow="ALWAYS" styleClass="stat-card">
            <Label styleClass="stat-label" text="OCCUPANCY RATE" />
            <Label fx:id="occupancyLabel" styleClass="stat-value" text="0%" />
        </VBox>

        <VBox HBox.hgrow="ALWAYS" styleClass="stat-card">
            <Label styleClass="stat-label" text="PENDING CHECK-INS" />
            <Label fx:id="pendingLabel" styleClass="stat-value" text="0" />
        </VBox>
    </HBox>

    <VBox spacing="10" VBox.vgrow="ALWAYS">
        <Label styleClass="topbar-title" text="Recent Bookings" />

        <TableView fx:id="recentBookingsTable" styleClass="dark-table" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colCustomer" prefWidth="150" text="Customer" />
                <TableColumn fx:id="colRoom"     prefWidth="100" text="Room" />
                <TableColumn fx:id="colStatus"   prefWidth="120" text="Status" />
                <TableColumn fx:id="colAmount"   prefWidth="120" text="Amount" />
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
        </TableView>
    </VBox>

</VBox>
