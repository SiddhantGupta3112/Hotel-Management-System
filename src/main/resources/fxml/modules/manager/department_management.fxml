<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<HBox spacing="20.0" prefHeight="600.0" prefWidth="900.0"
      stylesheets="@../../../css/main.css"
      xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.hotel.app.controller.modules.manager.DepartmentManagement">

    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <VBox spacing="10.0" HBox.hgrow="ALWAYS">
        <Label styleClass="module-header" text="Department Directory"
               style="-fx-font-size: 20px; -fx-font-weight: bold;" />

        <TableView fx:id="departmentTable" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="nameCol" prefWidth="250.0" text="Department Name" />
                <TableColumn fx:id="hodCol" prefWidth="250.0" text="Head of Department (HOD)" />
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
            <placeholder>
                <Label text="No departments found. Create one to get started." />
            </placeholder>
        </TableView>
    </VBox>

    <VBox spacing="15.0" prefWidth="300.0" styleClass="side-panel"
          style="-fx-background-color: #f9f9f9; -fx-padding: 20; -fx-border-color: #e0e0e0; -fx-border-width: 0 0 0 1;">

        <Label text="Create New Department"
               style="-fx-font-size: 16px; -fx-font-weight: bold;" />

        <Separator />

        <VBox spacing="5.0">
            <Label text="Department Name" />
            <TextField fx:id="deptNameField" promptText="e.g. Housekeeping" />
        </VBox>

        <Label text="Note: HOD can be assigned later via Staff Management."
               wrapText="true" style="-fx-font-size: 11px; -fx-text-fill: #7f8c8d;" />

        <Region VBox.vgrow="ALWAYS" />

        <Button maxWidth="Infinity" onAction="#handleCreateDepartment"
                styleClass="action-btn" text="SAVE DEPARTMENT"
                style="-fx-background-color: #2d3436; -fx-text-fill: white; -fx-padding: 10;" />
    </VBox>
</HBox>