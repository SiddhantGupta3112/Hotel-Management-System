<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<HBox spacing="20.0"
      styleClass="content-area"
      stylesheets="@../../../css/main.css"
      xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.hotel.app.controller.modules.manager.DepartmentManagement">

    <padding>
        <Insets bottom="20" left="20" right="20" top="20"/>
    </padding>

    <!-- LEFT: TABLE -->
    <VBox spacing="15" HBox.hgrow="ALWAYS">

        <Label text="Department Directory"
               styleClass="topbar-title"/>

        <TableView fx:id="departmentTable"
                   VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="nameCol" text="Department Name"/>
                <TableColumn fx:id="hodCol" text="HOD Name"/>
                <TableColumn fx:id="emailCol" text="HOD Email"/>
            </columns>

            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
            </columnResizePolicy>

            <placeholder>
                <Label text="No departments found. Create one to get started."
                       styleClass="muted-text"/>
            </placeholder>
        </TableView>
    </VBox>

    <!-- RIGHT: FORM PANEL -->
    <VBox spacing="20"
          prefWidth="320"
          styleClass="info-box">

        <Label text="CREATE DEPARTMENT"
               styleClass="info-box-title"/>

        <VBox styleClass="field-box">
            <Label text="DEPARTMENT NAME"
                   styleClass="field-label"/>
            <TextField fx:id="deptNameField"
                       promptText="e.g. Housekeeping"
                       styleClass="input-field"/>
        </VBox>

        <Label text="HOD can be assigned later via Staff Management."
               wrapText="true"
               styleClass="muted-text"/>

        <Region VBox.vgrow="ALWAYS"/>

        <Button text="SAVE DEPARTMENT"
                maxWidth="Infinity"
                onAction="#handleCreateDepartment"
                styleClass="primary-btn"/>
    </VBox>
</HBox>