<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<HBox spacing="20.0"
      styleClass="content-area"
      stylesheets="@../../../css/main.css"
      xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.hotel.app.controller.modules.manager.StaffManagement">

    <padding><Insets bottom="20" left="20" right="20" top="20"/></padding>

    <!-- LEFT SIDE -->
    <VBox spacing="15" HBox.hgrow="ALWAYS">

        <Label styleClass="topbar-title" text="Personnel Management"/>

        <TextField fx:id="searchField"
                   styleClass="input-field"
                   promptText="Search by name or email..."/>

        <TableView fx:id="staffTable" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colId" text="ID" prefWidth="60"/>
                <TableColumn fx:id="colName" text="Name" prefWidth="150"/>
                <TableColumn fx:id="colEmail" text="Email" prefWidth="180"/>
                <TableColumn fx:id="colRole" text="Role" prefWidth="100"/>
                <TableColumn fx:id="colDept" text="Department" prefWidth="120"/>
                <TableColumn fx:id="colStatus" text="Status" prefWidth="100"/>
            </columns>
        </TableView>
    </VBox>

    <!-- RIGHT SIDE FORM -->
    <ScrollPane fitToWidth="true" hbarPolicy="NEVER" prefWidth="380"
                style="-fx-background-color: transparent;">

        <VBox spacing="20">
            <padding><Insets right="15"/></padding>

            <VBox spacing="15" styleClass="info-box">

                <Label styleClass="info-box-title" text="STAFF REGISTRATION"/>

                <!-- IMPORTANT: RESTORED -->
                <CheckBox fx:id="hodCheckBox"
                          text="Register as Head of Dept (HOD)"
                          styleClass="field-label"
                          visible="false"
                          managed="false"
                          onAction="#handleHodCheckboxToggle"/>

                <VBox styleClass="field-box">
                    <Label text="FULL NAME" styleClass="field-label"/>
                    <TextField fx:id="nameField" styleClass="input-field"/>
                </VBox>

                <VBox styleClass="field-box">
                    <Label text="EMAIL" styleClass="field-label"/>
                    <TextField fx:id="emailField" styleClass="input-field"/>
                </VBox>

                <VBox styleClass="field-box">
                    <Label text="ROLE" styleClass="field-label"/>
                    <ComboBox fx:id="roleCombo" styleClass="input-field" maxWidth="Infinity"/>
                </VBox>

                <VBox styleClass="field-box">
                    <Label text="DEPARTMENT" styleClass="field-label"/>
                    <ComboBox fx:id="departmentCombo" styleClass="input-field" maxWidth="Infinity"/>
                </VBox>

                <!-- IMPORTANT: RESTORED -->
                <VBox fx:id="managerFieldBox" styleClass="field-box">
                    <Label text="REPORTING MANAGER" styleClass="field-label"/>
                    <ComboBox fx:id="managerCombo" styleClass="input-field" maxWidth="Infinity"/>
                </VBox>

                <VBox styleClass="field-box">
                    <Label text="JOB TITLE" styleClass="field-label"/>
                    <TextField fx:id="jobTitleField" styleClass="input-field"/>
                </VBox>

                <VBox styleClass="field-box">
                    <Label text="SALARY" styleClass="field-label"/>
                    <TextField fx:id="salaryField" styleClass="input-field"/>
                </VBox>

                <VBox styleClass="field-box">
                    <Label text="PASSWORD" styleClass="field-label"/>
                    <PasswordField fx:id="passwordField" styleClass="input-field"/>
                </VBox>

                <Button text="CREATE ACCOUNT"
                        styleClass="primary-btn"
                        maxWidth="Infinity"
                        onAction="#handleCreateStaff"/>

                <Label fx:id="formErrorLabel"
                       styleClass="error-label"
                       visible="false"
                       managed="false"/>

            </VBox>
        </VBox>
    </ScrollPane>
</HBox>