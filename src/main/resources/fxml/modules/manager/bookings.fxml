<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="15.0" styleClass="content-area"
      xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.hotel.app.controller.BookingController">

    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <!-- HEADER -->
    <HBox alignment="CENTER_LEFT" spacing="20.0">

        <Label text="Booking Management" styleClass="topbar-title" />

        <HBox spacing="5" alignment="CENTER_LEFT">
            <Label text="Active Stays:" styleClass="stat-label"/>
            <Label fx:id="statTotalActive" text="0" styleClass="stat-value-green"/>
        </HBox>

        <Region HBox.hgrow="ALWAYS" />

        <Button text="Sync Data"
                onAction="#handleRefresh"
                styleClass="button-secondary"/>
    </HBox>

    <!-- TABPANE -->
    <TabPane tabClosingPolicy="UNAVAILABLE" VBox.vgrow="ALWAYS">

        <!-- ALL BOOKINGS -->
        <Tab text="All Bookings">
            <VBox spacing="10.0">
                <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>

                <TableView fx:id="bookingsTable" VBox.vgrow="ALWAYS"/>

                <HBox alignment="CENTER_RIGHT">
                    <Button text="Generate Invoice for Selected"
                            onAction="#handleGenerateInvoice"
                            styleClass="button-primary"/>
                </HBox>
            </VBox>
        </Tab>

        <!-- BOOKING REQUESTS -->
        <Tab text="Booking Requests">
            <VBox spacing="10.0">
                <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>

                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label text="Pending Approvals:" styleClass="stat-label"/>
                    <Label fx:id="statPending" text="0" styleClass="stat-value-orange"/>
                </HBox>

                <TableView fx:id="pendingTable" VBox.vgrow="ALWAYS"/>

                <HBox spacing="10.0">
                    <Button text="Approve Booking"
                            onAction="#handleApproveBooking"
                            styleClass="button-primary"/>

                    <Button text="Reject"
                            onAction="#handleRejectBooking"
                            styleClass="button-danger"/>
                </HBox>
            </VBox>
        </Tab>

        <!-- CHECK-IN -->
        <Tab text="Check-in Requests">
            <VBox spacing="10.0">
                <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>

                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label text="Guests Awaiting Check-in:" styleClass="stat-label"/>
                    <Label fx:id="statCheckInRequests" text="0" styleClass="stat-value"/>
                </HBox>

                <TableView fx:id="checkInTable" VBox.vgrow="ALWAYS"/>

                <HBox spacing="10.0">
                    <Button text="Confirm Guest Arrival"
                            onAction="#handleApproveCheckIn"
                            styleClass="button-primary"/>

                    <Button text="Deny / Send Back"
                            onAction="#handleRejectCheckIn"
                            styleClass="button-secondary"/>
                </HBox>
            </VBox>
        </Tab>

        <!-- CHECK-OUT -->
        <Tab text="Check-out Requests">
            <VBox spacing="10.0">
                <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>

                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label text="Guests Awaiting Check-out:" styleClass="stat-label"/>
                    <Label fx:id="statCheckOutRequests" text="0" styleClass="stat-value-green"/>
                </HBox>

                <TableView fx:id="checkOutTable" VBox.vgrow="ALWAYS"/>

                <HBox spacing="10.0">
                    <Button text="Finalize Check-out &amp; Award Points"
                            onAction="#handleApproveCheckOut"
                            styleClass="button-primary"/>

                    <Button text="Keep Stay Active"
                            onAction="#handleRejectCheckOut"
                            styleClass="button-secondary"/>
                </HBox>
            </VBox>
        </Tab>

    </TabPane>

    <!-- FEEDBACK -->
    <Label fx:id="feedbackLabel"
           managed="false"
           visible="false"
           styleClass="error-label">
        <VBox.margin>
            <Insets top="5.0" />
        </VBox.margin>
    </Label>

</VBox>