<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<ScrollPane
        fitToWidth="true"
        styleClass="root-pane"
        stylesheets="@../../../css/main.css"
        xmlns="http://javafx.com/javafx/17"
        xmlns:fx="http://javafx.com/fxml/1"
        fx:controller="com.hotel.app.controller.modules.shared.MyProfileController">

    <VBox spacing="20.0" styleClass="page-bg">
        <padding>
            <Insets top="30.0" right="30.0" bottom="30.0" left="30.0"/>
        </padding>

        <!-- HEADER -->
        <VBox spacing="5">
            <Label text="Account Settings" styleClass="title-text"/>
            <Label text="View and update your personal and professional information."
                   styleClass="subtitle-text"/>
        </VBox>

        <!-- PERSONAL -->
        <VBox spacing="15" styleClass="card">
            <Label text="PERSONAL DETAILS" styleClass="section-title-red"/>

            <GridPane hgap="20" vgap="15">
                <columnConstraints>
                    <ColumnConstraints percentWidth="50"/>
                    <ColumnConstraints percentWidth="50"/>
                </columnConstraints>

                <VBox spacing="5" GridPane.columnIndex="0" GridPane.rowIndex="0">
                    <Label text="Full Name" styleClass="field-label"/>
                    <TextField fx:id="nameField" styleClass="form-control"/>
                </VBox>

                <VBox spacing="5" GridPane.columnIndex="1" GridPane.rowIndex="0">
                    <Label text="Email Address" styleClass="field-label"/>
                    <TextField fx:id="emailField" styleClass="form-control"/>
                </VBox>

                <VBox spacing="5" GridPane.columnIndex="0" GridPane.rowIndex="1">
                    <Label text="Country Code" styleClass="field-label"/>
                    <TextField fx:id="countryCodeField" promptText="+91" styleClass="form-control"/>
                </VBox>

                <VBox spacing="5" GridPane.columnIndex="1" GridPane.rowIndex="1">
                    <Label text="Phone Number" styleClass="field-label"/>
                    <TextField fx:id="phoneNumberField" styleClass="form-control"/>
                </VBox>

                <VBox spacing="5" GridPane.columnIndex="0" GridPane.rowIndex="2">
                    <Label text="Member Since" styleClass="field-label"/>
                    <TextField fx:id="memberSinceField" editable="false" styleClass="readonly-field"/>
                </VBox>
            </GridPane>

            <Button text="Save Changes"
                    onAction="#handleUpdateProfile"
                    styleClass="primary-button"/>
        </VBox>

        <!-- CUSTOMER -->
        <VBox fx:id="customerDetailsSection"
              managed="false"
              visible="false"
              spacing="15"
              styleClass="card">

            <Label text="CUSTOMER PROFILE" styleClass="section-title-red"/>

            <GridPane hgap="20" vgap="15">
                <columnConstraints>
                    <ColumnConstraints percentWidth="50"/>
                    <ColumnConstraints percentWidth="50"/>
                </columnConstraints>

                <VBox spacing="5" GridPane.columnIndex="0" GridPane.rowIndex="0">
                    <Label text="Residential Address" styleClass="field-label"/>
                    <TextField fx:id="addressField" styleClass="form-control"/>
                </VBox>

                <VBox spacing="5" GridPane.columnIndex="1" GridPane.rowIndex="0">
                    <Label text="Nationality" styleClass="field-label"/>
                    <TextField fx:id="nationalityField" styleClass="form-control"/>
                </VBox>

                <VBox spacing="5" GridPane.columnIndex="0" GridPane.rowIndex="1">
                    <Label text="ID / Passport Number" styleClass="field-label"/>
                    <TextField fx:id="idProofField" styleClass="form-control"/>
                </VBox>

                <VBox spacing="5" GridPane.columnIndex="1" GridPane.rowIndex="1">
                    <Label text="Loyalty Status" styleClass="field-label"/>
                    <Label fx:id="loyaltyPointsLabel" styleClass="loyalty-label"/>
                </VBox>

            </GridPane>

            <Button text="Save Customer Details"
                    onAction="#handleSaveCustomerDetails"
                    styleClass="primary-button-orange"/>
        </VBox>

        <!-- EMPLOYEE -->
        <VBox fx:id="employeeDetailsSection"
              managed="false"
              visible="false"
              spacing="15"
              styleClass="card">

            <Label text="EMPLOYMENT RECORD" styleClass="section-title-red"/>

            <GridPane hgap="20" vgap="15">
                <columnConstraints>
                    <ColumnConstraints percentWidth="50"/>
                    <ColumnConstraints percentWidth="50"/>
                </columnConstraints>

                <VBox spacing="5" GridPane.columnIndex="0" GridPane.rowIndex="0">
                    <Label text="Operational Role" styleClass="field-label"/>
                    <TextField fx:id="roleField" editable="false" styleClass="readonly-field"/>
                </VBox>

                <VBox spacing="5" GridPane.columnIndex="1" GridPane.rowIndex="0">
                    <Label text="Designation" styleClass="field-label"/>
                    <TextField fx:id="jobTitleField" editable="false" styleClass="readonly-field"/>
                </VBox>

                <VBox spacing="5" GridPane.columnIndex="0" GridPane.rowIndex="1">
                    <Label text="Assigned Department" styleClass="field-label"/>
                    <TextField fx:id="departmentField" editable="false" styleClass="readonly-field"/>
                </VBox>

                <VBox spacing="5" GridPane.columnIndex="1" GridPane.rowIndex="1">
                    <Label text="Reporting Authority" styleClass="field-label"/>
                    <TextField fx:id="managerNameField" editable="false" styleClass="readonly-field"/>
                </VBox>
            </GridPane>

            <Label text="Note: Employment details and roles are managed by HR/Administration."
                   styleClass="note-text"/>
        </VBox>

        <!-- SECURITY -->
        <VBox spacing="15" styleClass="card">
            <Label text="SECURITY" styleClass="section-title-red"/>

            <HBox spacing="20">
                <VBox spacing="5" HBox.hgrow="ALWAYS">
                    <Label text="New Password" styleClass="field-label"/>
                    <PasswordField fx:id="newPasswordField" styleClass="form-control"/>
                </VBox>

                <VBox spacing="5" HBox.hgrow="ALWAYS">
                    <Label text="Confirm Password" styleClass="field-label"/>
                    <PasswordField fx:id="confirmPasswordField" styleClass="form-control"/>
                </VBox>
            </HBox>

            <Button text="Update Password"
                    onAction="#handleChangePassword"
                    styleClass="dark-button"/>
        </VBox>

        <!-- DELETE -->
        <VBox spacing="10">
            <Separator/>
            <HBox spacing="20" alignment="CENTER_LEFT">
                <Button text="Request Account Deletion"
                        onAction="#handleDeleteAccount"
                        styleClass="danger-outline-button"/>
                <Label fx:id="statusLabel" styleClass="status-label"/>
            </HBox>
        </VBox>

    </VBox>
</ScrollPane>