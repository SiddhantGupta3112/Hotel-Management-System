<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="720.0" prefWidth="1080.0" styleClass="root-pane" stylesheets="@../css/main.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.hotel.app.controller.ManagerDashboardController">
    <left>
        <VBox prefWidth="220.0" styleClass="sidebar">
            <VBox styleClass="sidebar-brand">
                <Label styleClass="brand-icon" text="M" />
                <Label styleClass="sidebar-title" text="ADMIN CONSOLE" />
                <Label styleClass="sidebar-subtitle" text="Management &amp; Analytics" />
            </VBox>
            <VBox fx:id="navContainer" spacing="2" VBox.vgrow="ALWAYS">
                <Label onMouseClicked="#handleNavigation" styleClass="nav-item-active" text="Overview" />
                <Label onMouseClicked="#handleNavigation" styleClass="nav-item" text="Rooms &amp; Inventory" />
                <Label onMouseClicked="#handleNavigation" styleClass="nav-item" text="Bookings" />
                <Label onMouseClicked="#handleNavigation" styleClass="nav-item" text="Staff Management" />
                <Label onMouseClicked="#handleNavigation" styleClass="nav-item" text="Department Management" />
                <Label onMouseClicked="#handleNavigation" styleClass="nav-item" text="Reports" />
                <Label onMouseClicked="#handleNavigation" styleClass="nav-item" text="My Profile" />
            </VBox>
            <VBox styleClass="sidebar-footer">
                <Button maxWidth="Infinity" onAction="#handleLogout" styleClass="logout-btn" text="LOGOUT" />
            </VBox>
        </VBox>
    </left>
    <center>
        <VBox styleClass="content-area">
            <HBox alignment="CENTER_LEFT" spacing="20" styleClass="topbar">
                <Label fx:id="pageTitle" styleClass="topbar-title" text="Overview" />
                <Region HBox.hgrow="ALWAYS" />
                <VBox alignment="CENTER_RIGHT">
                    <Label fx:id="userNameLabel" styleClass="topbar-username" text="Manager Name" />
                    <Label fx:id="userRoleLabel" styleClass="topbar-role" text="GENERAL MANAGER" />
                </VBox>
                <Label fx:id="avatarLabel" styleClass="avatar-circle" text="M" />
            </HBox>
            <StackPane fx:id="contentPlaceholder" VBox.vgrow="ALWAYS" />
        </VBox>
    </center>
</BorderPane>