<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.hotel.app.controller.SignupController"
           styleClass="root-pane"
           stylesheets="@../css/main.css">

    <VBox styleClass="login-card" maxWidth="420" maxHeight="620"
          StackPane.alignment="CENTER">

        <VBox styleClass="brand-box" alignment="CENTER">
            <Label text="H" styleClass="brand-icon"/>
            <Label text="Hotel Management System" styleClass="brand-title"/>
            <Label text="Create your account" styleClass="brand-subtitle"/>
        </VBox>

        <Label fx:id="errorLabel" styleClass="error-label" wrapText="true"
               managed="false" visible="false"/>

        <VBox styleClass="field-box">
            <Label text="FULL NAME" styleClass="field-label"/>
            <TextField fx:id="nameField" promptText="John Smith"
                       styleClass="input-field"/>
        </VBox>

        <VBox styleClass="field-box">
            <Label text="EMAIL" styleClass="field-label"/>
            <TextField fx:id="emailField" promptText="john@example.com"
                       styleClass="input-field"/>
        </VBox>

        <VBox styleClass="field-box">
            <Label text="PHONE" styleClass="field-label"/>
            <HBox spacing="10">
                <TextField fx:id="countryCodeField" promptText="+91"
                           styleClass="input-field" prefWidth="100"/>
                <TextField fx:id="phoneNumberField" promptText="9999999999"
                           styleClass="input-field" HBox.hgrow="ALWAYS"/>
            </HBox>
        </VBox>

        <VBox styleClass="field-box">
            <Label text="PASSWORD" styleClass="field-label"/>
            <PasswordField fx:id="passwordField" promptText="Min. 8 characters"
                           styleClass="input-field"/>
        </VBox>

        <VBox styleClass="field-box">
            <Label text="CONFIRM PASSWORD" styleClass="field-label"/>
            <PasswordField fx:id="confirmPasswordField" promptText="••••••••"
                           styleClass="input-field"/>
        </VBox>

        <Button text="Create Account" styleClass="primary-btn"
                onAction="#handleSignup" maxWidth="Infinity"/>

        <Separator styleClass="divider"/>

        <HBox alignment="CENTER" spacing="4">
            <Label text="Already have an account?" styleClass="muted-text"/>
            <Hyperlink text="Sign in" styleClass="link-text"
                       onAction="#handleLogin"/>
        </HBox>

        <VBox.margin>
            <Insets top="28" right="40" bottom="28" left="40"/>
        </VBox.margin>

    </VBox>

</StackPane>