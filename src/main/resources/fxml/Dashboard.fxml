<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>

<BorderPane fx:id="mainPane" prefHeight="720.0" prefWidth="1080.0" styleClass="root-pane" stylesheets="@../css/main.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.hotel.app.controller.DashboardController">

    <left>
        <VBox prefWidth="220.0" styleClass="sidebar">
            <VBox styleClass="sidebar-brand">
                <Label styleClass="brand-icon" text="H" />
                <Label styleClass="sidebar-title" text="GRAND HOTEL" />
                <Label styleClass="sidebar-subtitle" text="Management System" />
            </VBox>

            <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;">
                <VBox fx:id="navContainer" spacing="2" styleClass="sidebar">
                    <Label fx:id="navOverview" onMouseClicked="#handleNavigation" styleClass="nav-item-active" text="Overview" />
                    <Label fx:id="navBookings" onMouseClicked="#handleNavigation" styleClass="nav-item" text="Bookings" />
                    <Label fx:id="navRooms" onMouseClicked="#handleNavigation" styleClass="nav-item" text="Rooms &amp; Inventory" />
                    <Label fx:id="navStaff" onMouseClicked="#handleNavigation" styleClass="nav-item" text="Staff Management" />
                    <Label fx:id="navReports" onMouseClicked="#handleNavigation" styleClass="nav-item" text="Reports" />
                </VBox>
            </ScrollPane>

            <Region VBox.vgrow="ALWAYS" />

            <VBox styleClass="sidebar-footer">
                <Button maxWidth="Infinity" onAction="#handleLogout" styleClass="logout-btn" text="LOGOUT" />
            </VBox>
        </VBox>
    </left>

    <center>
        <VBox styleClass="content-area">
            <HBox alignment="CENTER_LEFT" spacing="20" styleClass="topbar">
                <Label fx:id="pageTitle" styleClass="topbar-title" text="Overview" />
                <Region HBox.hgrow="ALWAYS" />
                <VBox alignment="CENTER_RIGHT">
                    <Label fx:id="userNameLabel" styleClass="topbar-username" text="User Name" />
                    <Label fx:id="userRoleLabel" styleClass="topbar-role" text="MANAGER" />
                </VBox>
                <Label fx:id="avatarLabel" styleClass="avatar-circle" text="JD" />
            </HBox>

            <StackPane fx:id="contentPlaceholder" VBox.vgrow="ALWAYS">
                <Label styleClass="muted-text" text="Loading module..." />
            </StackPane>
        </VBox>
    </center>
</BorderPane>