<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<HBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.hotel.app.controller.DashboardController"
      styleClass="root-pane"
      stylesheets="@../css/main.css"
      prefWidth="1280" prefHeight="720">

    <!-- ═══════════════ SIDEBAR ═══════════════ -->
    <VBox styleClass="sidebar" prefWidth="210">

        <VBox styleClass="sidebar-brand">
            <Label text="Hotel Management" styleClass="sidebar-title"/>
            <Label text="System v1.0"      styleClass="sidebar-subtitle"/>
        </VBox>

        <!-- Nav items — onAction fires the handler in DashboardController -->
        <Label fx:id="navDashboard" text="⬛  Dashboard"  styleClass="nav-item-active"
               onMouseClicked="#handleNavDashboard"/>
        <Label fx:id="navRooms"     text="🛏  Rooms"       styleClass="nav-item"
               onMouseClicked="#handleNavRooms"/>
        <Label fx:id="navBookings"  text="📋  Bookings"    styleClass="nav-item"
               onMouseClicked="#handleNavBookings"/>
        <Label fx:id="navCustomers" text="👤  Customers"   styleClass="nav-item"
               onMouseClicked="#handleNavCustomers"/>
        <Label fx:id="navBilling"   text="💳  Billing"     styleClass="nav-item"
               onMouseClicked="#handleNavBilling"/>

        <Region VBox.vgrow="ALWAYS"/>

        <VBox styleClass="sidebar-footer">
            <Button text="Sign Out" styleClass="logout-btn"
                    onAction="#handleLogout" maxWidth="Infinity"/>
        </VBox>
    </VBox>

    <!-- ═══════════════ MAIN AREA ═══════════════ -->
    <VBox HBox.hgrow="ALWAYS">

        <!-- Top bar -->
        <HBox styleClass="topbar" alignment="CENTER_LEFT">
            <Label text="Dashboard" styleClass="topbar-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <HBox spacing="10" alignment="CENTER">
                <Label fx:id="avatarLabel"  styleClass="avatar-circle"/>
                <VBox>
                    <Label fx:id="userNameLabel" styleClass="topbar-username"/>
                    <Label fx:id="userRoleLabel"  styleClass="topbar-role"/>
                </VBox>
            </HBox>
        </HBox>

        <!-- Content swap pane — sections load here -->
        <StackPane fx:id="contentPane" VBox.vgrow="ALWAYS">

            <!-- ── Dashboard Home (always visible until a nav item is clicked) ── -->
            <VBox styleClass="content-area" spacing="16">
                <VBox.margin><Insets top="20" right="20" bottom="20" left="20"/></VBox.margin>

                <!-- Row 1 — Room stats -->
                <HBox spacing="12">
                    <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
                        <Label text="TOTAL ROOMS"     styleClass="stat-label"/>
                        <Label fx:id="statTotalRooms" styleClass="stat-value"/>
                    </VBox>
                    <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
                        <Label text="AVAILABLE"           styleClass="stat-label"/>
                        <Label fx:id="statAvailableRooms" styleClass="stat-value-green"/>
                    </VBox>
                    <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
                        <Label text="TODAY CHECK-INS"    styleClass="stat-label"/>
                        <Label fx:id="statTodayCheckIns" styleClass="stat-value"/>
                    </VBox>
                    <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
                        <Label text="TODAY CHECK-OUTS"     styleClass="stat-label"/>
                        <Label fx:id="statTodayCheckOuts"  styleClass="stat-value"/>
                    </VBox>
                </HBox>

                <!-- Row 2 — Revenue stats -->
                <HBox spacing="12">
                    <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
                        <Label text="TODAY'S REVENUE"   styleClass="stat-label"/>
                        <Label fx:id="statTodayRevenue" styleClass="stat-value-green"/>
                    </VBox>
                    <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
                        <Label text="THIS MONTH"        styleClass="stat-label"/>
                        <Label fx:id="statMonthRevenue" styleClass="stat-value-green"/>
                    </VBox>
                </HBox>

                <!-- Recent bookings -->
                <VBox styleClass="info-box" VBox.vgrow="ALWAYS" spacing="10">
                    <Label text="RECENT BOOKINGS" styleClass="info-box-title"/>

                    <TableView fx:id="recentBookingsTable" VBox.vgrow="ALWAYS"
                               styleClass="dark-table">
                        <columns>
                            <TableColumn fx:id="colBookingId" text="#"         prefWidth="50"/>
                            <TableColumn fx:id="colCustomer"  text="Guest"     prefWidth="160"/>
                            <TableColumn fx:id="colRoom"      text="Room"      prefWidth="60"/>
                            <TableColumn fx:id="colRoomType"  text="Type"      prefWidth="140"/>
                            <TableColumn fx:id="colCheckIn"   text="Check In"  prefWidth="100"/>
                            <TableColumn fx:id="colCheckOut"  text="Check Out" prefWidth="100"/>
                            <TableColumn fx:id="colStatus"    text="Status"    prefWidth="120"/>
                        </columns>
                        <placeholder>
                            <Label text="No bookings yet" styleClass="muted-text"/>
                        </placeholder>
                    </TableView>
                </VBox>

            </VBox>
        </StackPane>
    </VBox>

</HBox>
